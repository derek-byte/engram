  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Base permissions for the main (search) window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
