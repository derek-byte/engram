{
  "name": "engram",
  "version": "0.1.0",
  "description": "Global semantic memory for your coding sessions",
  "type": "module",
  "bin": {
    "engram": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "app:dev": "cd app && bun install && bun run dev",
    "app:build": "cd app && bun install && bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "fastembed": "^2.1.0",
    "openai": "^4.68.0",
    "postgres": "^3.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.2.21"
  },
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
