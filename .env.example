# Copy this file to .env and fill in real values.
# .env is gitignored. Values here override ~/.engram/config.json at runtime.

OPENAI_API_KEY=sk-...

# Embedding provider: openai (default, needs OPENAI_API_KEY) or local
# (all-MiniLM-L6-v2 ONNX via fastembed, no key, model cached to ~/.engram/models).
# openai falls back to local automatically if the API is down or the key is missing.
# ENGRAM_EMBEDDING_PROVIDER=local

# Default: local Postgres via docker-compose (recommended for personal use).
# Start it with: docker compose up -d
ENGRAM_DATABASE_URL=postgresql://engram:engram@localhost:5432/engram

# Alternative: Neon (zero local dependency, ~50-200ms latency, data leaves your machine).
# Get a free connection string at neon.tech and uncomment the line below instead.
# ENGRAM_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/engram?sslmode=require

# Optional: MemPalace (benchmark reference, see scripts/setup-mempalace.sh)
# MEMPALACE_PGVECTOR_DSN=postgresql://engram:engram@localhost:5432/mempalace
